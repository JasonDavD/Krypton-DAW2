# ===== Backend: Java / Maven =====
backend/target/
**/*.class

# ===== Microservicios: Java / Maven =====
services/**/target/
# Imágenes subidas en runtime por catalog-service (./uploads al correr desde services/).
services/uploads/

# Imágenes subidas en runtime (galería de productos): no versionar el contenido,
# pero mantener el directorio para que la app encuentre ./uploads en un clone fresco.
backend/uploads/*
!backend/uploads/.gitkeep

# ===== Frontend: Node (a futuro) =====
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*

